rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth Helpers
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Récupérer le rôle depuis le document agent de l'utilisateur
    function getUserData() {
      let path = /databases/$(database)/documents/agents/$(request.auth.uid);
      return exists(path) ? get(path).data : {};
    }
    
    function hasRole(role) {
      let data = getUserData();
      return isAuthenticated() && (data != null && data.role == role);
    }
    
    // Rôles
    function isAdmin() { return hasRole('admin'); }
    function isManager() { return hasRole('manager'); }
    function isAdminOrManager() { 
      return isAdmin() || isManager(); 
    }

    // --- PORTAIL CLIENT ---
    // Rôle 'client' stocké dans agents/{uid}.role = 'client'
    // App minimale /client/ : isolation par siteId (Firestore field agents/{uid}.siteId)
    // App avancée /clients/ : isolation par clientId (custom claim Auth token)
    //   clientId = doc ID dans la collection clients/, pas UID Auth
    function isClient() { return hasRole('client'); }
    function clientSiteId() { return getUserData().siteId; }
    function clientTokenId() { return request.auth.token.clientId; }


    // --- COLLECTIONS ---

    // 1. CONSIGNES
    match /consignes/{consigneId} {
      allow read: if (isAuthenticated() && !isClient())
                  || (isClient() && resource.data.targetId == clientSiteId());
      allow create: if isAdminOrManager()
                    || (isClient()
                        && request.resource.data.clientId == clientTokenId()
                        && request.resource.data.source == 'client');
      allow update, delete: if isAdminOrManager();
    }

    // 2. AGENTS
    // R10A: lecture restreinte — self ou admin/manager
    match /agents/{userId} {
      allow read: if isAdminOrManager()
                  || (isAuthenticated() && request.auth.uid == userId);
      allow create: if (isAuthenticated() && request.auth.uid == userId) || isAdminOrManager();
      allow update: if isAdminOrManager() || (isAuthenticated() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }
    
    // 3. PLANNING
    match /planning/{shiftId} {
      allow read: if isAuthenticated() && !isClient();
      allow write: if isAdminOrManager();
    }

    // 4. EVENTS (Main Courante)
    match /events/{eventId} {
      allow read: if isAuthenticated() && !isClient();
      allow create: if isAuthenticated() && !isClient();
      allow update: if isAdminOrManager();
      allow delete: if isAdminOrManager();
    }

    // 5. SITES — supporte les 4 queries de l'app avancée
    match /sites/{siteId} {
      allow read: if isAdminOrManager()
                  || (isAuthenticated() && !isClient())
                  || (isClient() && siteId == clientSiteId())
                  || (isClient() && clientTokenId() in resource.data.clientIds)
                  || (isClient() && clientTokenId() in resource.data.authorizedClients)
                  || (isClient() && resource.data.primaryClientId == clientTokenId())
                  || (isClient() && resource.data.clientId == clientTokenId());
      allow write: if isAdminOrManager();
    }

    // 6. SHIFT SEGMENTS — lecture client par clientId
    match /shiftSegments/{segmentId} {
      allow read: if isAdminOrManager()
                  || (isAuthenticated() && !isClient())
                  || (isClient() && resource.data.clientId == clientTokenId());
      allow write: if isAdminOrManager();
    }

    // 7. CLIENT REQUESTS — lecture + création client
    match /clientRequests/{requestId} {
      allow read: if isAdminOrManager()
                  || (isClient() && resource.data.clientId == clientTokenId());
      allow create: if isClient() && request.resource.data.clientId == clientTokenId();
      allow update, delete: if isAdminOrManager();

      // Comments sub-collection
      match /comments/{commentId} {
        allow read: if isAdminOrManager()
                    || (isClient() && clientTokenId() != null);
        allow create: if (isClient() && request.resource.data.authorId == clientTokenId())
                      || isAdminOrManager();
        allow update, delete: if isAdminOrManager();
      }
    }

    // 8. REPORTS — lecture client + création incidents
    match /reports/{reportId} {
      allow read: if isAdminOrManager()
                  || (isClient() && resource.data.clientId == clientTokenId());
      allow create: if isAdminOrManager()
                    || (isClient()
                        && request.resource.data.clientId == clientTokenId()
                        && request.resource.data.source == 'client');
      allow update, delete: if isAdminOrManager();

      // Comments sub-collection
      match /comments/{commentId} {
        allow read: if isAdminOrManager()
                    || (isClient() && clientTokenId() != null);
        allow create: if (isClient() && request.resource.data.authorId == clientTokenId())
                      || isAdminOrManager();
        allow update, delete: if isAdminOrManager();
      }
    }

    // 9. DOCUMENTS — lecture client si visible
    match /documents/{documentId} {
      allow read: if isAdminOrManager()
                  || (isClient()
                      && resource.data.clientId == clientTokenId()
                      && resource.data.visibility.client == true);
      allow write: if isAdminOrManager();
    }

    // 10. CLIENTS — lecture propre doc
    match /clients/{docId} {
      allow read: if isAdminOrManager()
                  || (isClient() && docId == clientTokenId());
      allow write: if isAdminOrManager();
    }

    // 11. CLIENT SITE PROFILES
    match /clientSiteProfiles/{profileId} {
      allow read: if isAdminOrManager()
                  || (isClient() && resource.data.clientId == clientTokenId());
      allow write: if isAdminOrManager();
    }

    // 12. DOCUMENT DOWNLOADS — traçabilité téléchargements (R15)
    match /documentDownloads/{downloadId} {
      allow read: if isAdminOrManager()
                  || (isClient() && resource.data.clientId == clientTokenId());
      allow write: if isAdminOrManager();
    }

    // Default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
