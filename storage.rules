rules_version = '2';

// R10A — Storage Rules sécurisées
// Lecture globale supprimée. Chaque path a ses propres règles.
// Les Cloud Functions (Admin SDK) contournent les rules pour les signed URLs.
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helper functions ──────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdminOrManager() {
      return isSignedIn()
        && firestore.get(/databases/(default)/documents/agents/$(request.auth.uid)).data.role
           in ['admin', 'manager'];
    }

    // ── Agent Photos ──────────────────────────────────────────
    // Admin / manager : accès total au namespace agent_photos
    match /agent_photos/{allPaths=**} {
      allow read, write: if isAdminOrManager();
    }

    // Agent propriétaire : accès à son propre dossier uniquement
    match /agent_photos/{agentUid}/{fileName} {
      allow read, write: if isSignedIn() && request.auth.uid == agentUid;
    }

    // ── Report Photos (Main Courante) ─────────────────────────
    // Path: report_photos/{userId}/{filename}
    // Read : propriétaire OU admin/manager
    // Write : propriétaire uniquement
    match /report_photos/{userId}/{fileName} {
      allow read: if request.auth != null
                  && (request.auth.uid == userId
                      || firestore.get(/databases/(default)/documents/agents/$(request.auth.uid)).data.role in ['admin', 'manager']);
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }

    // ── Badges PDF ────────────────────────────────────────────
    // Path: badges/{filename}
    // Read : admin/manager uniquement (clients via getAgentBadgeSignedUrl function)
    // Write : admin/manager uniquement
    match /badges/{fileName} {
      allow read: if request.auth != null
                  && firestore.get(/databases/(default)/documents/agents/$(request.auth.uid)).data.role in ['admin', 'manager'];
      allow write: if request.auth != null
                   && firestore.get(/databases/(default)/documents/agents/$(request.auth.uid)).data.role in ['admin', 'manager'];
    }

    // ── Documents clients ─────────────────────────────────────
    // Path: documents/{clientId}/{filename} ou tout storagePath
    // Pas de lecture directe — accès uniquement via getDocumentSignedUrl (Admin SDK)
    // Write : admin/manager uniquement (upload console ou function future)
    match /documents/{allPaths=**} {
      allow read: if request.auth != null
                  && firestore.get(/databases/(default)/documents/agents/$(request.auth.uid)).data.role in ['admin', 'manager'];
      allow write: if request.auth != null
                   && firestore.get(/databases/(default)/documents/agents/$(request.auth.uid)).data.role in ['admin', 'manager'];
    }

    // ── Client Uploads ────────────────────────────────────────
    // Path: clientUploads/{clientId}/{filename}
    // Read : le client propriétaire (via claim) OU admin/manager
    // Write : le client propriétaire (via claim) OU admin/manager
    match /clientUploads/{clientId}/{fileName} {
      allow read: if request.auth != null
                  && (request.auth.token.clientId == clientId
                      || firestore.get(/databases/(default)/documents/agents/$(request.auth.uid)).data.role in ['admin', 'manager']);
      allow write: if request.auth != null
                   && (request.auth.token.clientId == clientId
                       || firestore.get(/databases/(default)/documents/agents/$(request.auth.uid)).data.role in ['admin', 'manager']);
    }

    // ── Default : deny all ────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
